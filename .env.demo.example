# ── Aegis Lite — Public Demo Deployment ──────────────────────────────────────
#
# Environment variables for aegis-lite.jesseboudreau.com
# Copy to .env in your deployment, fill in the values below.
#
# IMPORTANT: Rotate all keys before committing or deploying.
# This file is a template only — it contains NO real values.

# ── Edition ───────────────────────────────────────────────────────────────────
AEGIS_EDITION=lite
DEPLOYMENT_NAME=demo
PUBLIC_URL=https://aegis-lite.jesseboudreau.com

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Enables seeded synthetic governance events, shows all providers as connected,
# and allows a weak SECRET_KEY (only because DEMO_MODE=true bypasses validation).
DEMO_MODE=true
LOCAL_DEV=false

# ── Auth ──────────────────────────────────────────────────────────────────────
# Even in demo mode, use a real strong secret for JWT signing.
# Generate: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_REAL_SECRET

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite is fine for a read-mostly demo deployment.
# For a high-traffic public demo, switch to PostgreSQL.
DATABASE_URL=sqlite+aiosqlite:////app/data/aegis_demo.db

# ── AI Provider Keys (optional in demo mode) ──────────────────────────────────
# If keys are provided, live AI responses will work.
# If empty, all models return demo-mode simulated responses.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=

# ── Defaults ──────────────────────────────────────────────────────────────────
DEFAULT_MONTHLY_BUDGET=5.0
CORS_ORIGINS=https://aegis-lite.jesseboudreau.com,http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
API_URL=http://backend:8100
