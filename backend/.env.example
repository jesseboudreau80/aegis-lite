# ── Aegis Lite — Backend Environment ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── App identity ──────────────────────────────────────────────────────────────
AEGIS_EDITION=lite
DEPLOYMENT_NAME=local

# Public URL (used for CORS and status links in demo mode)
PUBLIC_URL=http://localhost:3007

# ── Security ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for development)
DATABASE_URL=sqlite+aiosqlite:///./aegis_lite.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aegis_lite

# ── AI Provider Keys ─────────────────────────────────────────────────────────
# At minimum, add OPENROUTER_API_KEY for free-tier models (no billing required).
# Other providers are optional — Aegis falls back to free models when not set.

# OpenRouter — free tier available at https://openrouter.ai
# Enables: Llama, GPT OSS, Gemma, and other free models
OPENROUTER_API_KEY=

# Anthropic — https://console.anthropic.com
# Enables: Claude Sonnet, Claude Opus
ANTHROPIC_API_KEY=

# OpenAI — https://platform.openai.com
# Enables: GPT-4o, GPT-4o Mini
OPENAI_API_KEY=

# Perplexity — https://www.perplexity.ai/settings/api
# Enables: web-grounded research with citations
PERPLEXITY_API_KEY=

# ── Budget ────────────────────────────────────────────────────────────────────
# Default monthly budget per user (USD). Set 0 for unlimited.
DEFAULT_MONTHLY_BUDGET=20.0

# ── Demo mode ─────────────────────────────────────────────────────────────────
# Set to true to enable seeded demo data for the public demo deployment.
# In demo mode, demo users (admin@example.com / demo@example.com) are seeded.
# AuditLog and governance events still reflect REAL activity from actual usage.
DEMO_MODE=false

# ── Development ───────────────────────────────────────────────────────────────
# LOCAL_DEV=true enables the X-User-Email bypass header (dev only, never production)
LOCAL_DEV=false

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3007,http://localhost:3000
